  .test-card__author { display:flex; align-items:center; gap:12px; }
  .test-card__avatar { width:42px; height:42px; border-radius:50%; background: var(--azul); display:flex; align-items:center; justify-content:center; font-family:'Barlow Condensed',sans-serif; font-weight:900; font-size:18px; color:#fff; flex-shrink:0; }
